{
  "name": "ffxi-addon-hub",
  "version": "1.0.8",
  "description": "FFXI Windower Addon Manager",
  "main": "main.js",
  "author": "Garyfromwork",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish=never",
    "release": "electron-builder --publish=always"
  },
  "build": {
    "appId": "com.ffxi.addon-manager",
    "productName": "FFXI Addon HUB",
    "copyright": "Copyright © 2026",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "config.js",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Garyfromwork",
      "repo": "FFXI-Addon-HUB"
    },
    "win": {
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FFXI Addon HUB"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Game",
      "description": "FFXI Windower Addon Manager"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "adm-zip": "^0.5.17",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.4"
  }
}
